ASSIGNMENT = 'set', LETTERS, '=', EXPRESSION, ';' ;

VAR_DECL   = 'set', LETTERS, ':', TYPE, '=', EXPRESSION, ';' ;

EXPRESSION = OR_EXPR ;

OR_EXPR = AND_EXPR, { 'or', AND_EXPR } ;

AND_EXPR = NOT_EXPR, { 'and', NOT_EXPR } ;

NOT_EXPR = [ 'not' ], COMP_EXPR ;

COMP_EXPR = ARITH_EXPR, { ( '==' | '!==' | '<' | '<=' | '>' | '>=' ), ARITH_EXPR } ;

ARITH_EXPR = TERM, { ('+' | '-'), TERM } ;

TERM = FACTOR, { ('*' | '/'), FACTOR } ;

COMMAND    = LETTERS, ( '=' | '+=' | '-=' | '*=' | '/=' ), EXPRESSION, ';' ;

INCREMENT  = LETTERS, ( '++' | '--' ), ';' ;

STATEMENTS = { IF_STMT | WHILE_STMT | FOR_STMT | COMMAND | INCREMENT | VAR_DECL | EXPRESSION_STATEMENT | RETURN_STMT } ;

IF_STMT = 'if', EXPRESSION, '{', STATEMENTS, '}', [ 'else', ( IF_STMT | '{', STATEMENTS, '}' ) ] ;

WHILE_STMT = 'while', EXPRESSION, '{', STATEMENTS, '}' ;

FOR_STMT = 'for', VAR_DECL, EXPRESSION, ';', EXPRESSION, '{', STATEMENTS, '}' ;

FACTOR = VALUE | LETTERS | '(', EXPRESSION, ')' | FUNCTION_CALL | INTERPOLATED_STRING ;

VALUE = NUMBER | STRING | 'true' | 'false' ;

TYPE = 'i32' | 'i64' | 'u32' | 'u64' | 'f32' | 'f64' | 'string' | 'bool' | 'void' ;

INTERPOLATED_STRING = '"', { CHAR | '${', EXPRESSION, '}' }, '"' ;

FUNCTION_CALL = LETTERS, '(', [ ARGS ], ')' ;

ARGS = EXPRESSION, { ',', EXPRESSION } ;

RETURN_STMT = 'return', [ EXPRESSION ], ';' ;