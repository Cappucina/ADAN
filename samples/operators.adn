import "adan/io";

set x: i32 = 10;
set y: i32 = 0;

fun main(): i32 {
    println(`Initial x: ${x}`);

    x += 5;
    println(`x += 5: ${x}`);

    x -= 3;
    println(`x -= 3: ${x}`);

    x *= 2;
    println(`x *= 2: ${x}`);

    x /= 4;
    println(`x /= 4: ${x}`);

    x++;
    println(`x++: ${x}`);

    x--;
    println(`x--: ${x}`);

    while y < 5 {
        println(`y is ${y}`);
        y += 1;
    }

    return 0;
}
